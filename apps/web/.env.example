# Database
DATABASE_URL="postgresql://ukcg:ukcg_dev_password@localhost:5433/ukcg?schema=public"

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# AI (optional — disabled by default)
# AI_PROVIDER=openai
# AI_API_KEY=
# AI_MODEL_RFQ_NORMALIZER=gpt-4o-mini
# AI_MODEL_DOCUMENT_CHECK=gpt-4o-mini
# AI_MODEL_CLOSEOUT_SUMMARY=gpt-4o-mini
# AI_REQUEST_TIMEOUT_MS=10000
# AI_DAILY_USER_LIMIT=20
# AI_DAILY_ORG_LIMIT=100

# Object Storage (optional — local filesystem by default)
# STORAGE_PROVIDER=s3
# STORAGE_BUCKET=
# STORAGE_REGION=
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=
# STORAGE_ENDPOINT=

# Node
NODE_ENV=development
